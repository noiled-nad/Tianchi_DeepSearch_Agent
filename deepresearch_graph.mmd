---
config:
  flowchart:
    curve: linear
---
graph TD;
	__start__([<p>__start__</p>]):::first
	parse_claims(parse_claims)
	plan_queries(plan_queries)
	retrieve(retrieve)
	extract_notes(extract_notes)
	judge_claims(judge_claims)
	finalize(finalize)
	__end__([<p>__end__</p>]):::last
	__start__ --> parse_claims;
	extract_notes --> judge_claims;
	judge_claims -.-> finalize;
	judge_claims -.-> plan_queries;
	parse_claims --> plan_queries;
	plan_queries --> retrieve;
	retrieve --> extract_notes;
	finalize --> __end__;
	classDef default fill:#f2f0ff,line-height:1.2
	classDef first fill-opacity:0
	classDef last fill:#bfb6fc
